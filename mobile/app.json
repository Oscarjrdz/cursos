{
  "expo": {
    "name": "Candidatic Knowledge",
    "slug": "knowledgeapp",
    "scheme": "knowledgeapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#7c3aed"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.candidatic.knowledge",
      "buildNumber": "1",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Necesitamos acceso a tus fotos para cambiar tu foto de perfil.",
        "CFBundleAllowMixedLocalizations": true
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#7c3aed"
      },
      "package": "com.candidatic.knowledge",
      "versionCode": 1,
      "edgeToEdgeEnabled": false,
      "predictiveBackGestureEnabled": false,
      "permissions": ["INTERNET"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        { "photosPermission": "Necesitamos acceso a tus fotos para cambiar tu foto de perfil." }
      ]
    ],
    "updates": {
      "url": "https://u.expo.dev/13045748-db7d-4107-bf74-d8f3817ff58e"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "13045748-db7d-4107-bf74-d8f3817ff58e"
      }
    },
    "owner": "oscarjrdz"
  }
}
