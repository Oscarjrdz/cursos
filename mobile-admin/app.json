{
  "expo": {
    "name": "Admin Knowledge",
    "slug": "admin-knowledge",
    "scheme": "adminknowledge",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#7c3aed"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.candidatic.admin",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#7c3aed"
      },
      "package": "com.candidatic.admin",
      "versionCode": 1,
      "edgeToEdgeEnabled": false,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Necesitamos acceso a tus fotos para el logo de la empresa."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "dff3fa02-f801-4220-9208-b6e90c577cb4"
      }
    },
    "owner": "oscarjrdz"
  }
}
