{
  "cli": {
    "version": ">= 18.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal"
    },
    "apk": {
      "distribution": "internal",
      "channel": "production",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://knowledge.candidatic.com"
      }
    },
    "production": {
      "autoIncrement": true,
      "distribution": "store",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://knowledge.candidatic.com"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "oscarjrdz@gmail.com",
        "ascAppId": "6774632845",
        "appleTeamId": "C96CVWWJ32"
      }
    }
  }
}
